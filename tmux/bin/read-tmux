#!/usr/bin/env bash
# read-tmux <pane_id>
#
# Reads output from a tmux pane identified by its unique pane_id (e.g. %42).
# First call: captures visible screen up to cursor, saves position marker.
# Subsequent calls: captures only new lines since last read.
#
# Position = history_size + cursor_y — tracks total lines written, accurate
# even when output hasn't scrolled into the scrollback buffer yet.
#
# --tui mode: captures full visible screen (for TUI apps like vim, htop).
#
# Output is capped: first 2000 bytes + last 2000 bytes, middle truncated.

set -euo pipefail

# Garbage-collect state dirs for dead panes (runs in background, best-effort)
(
  STATE_ROOT="/tmp/tmux-skill"
  if [[ -d "$STATE_ROOT" ]]; then
    for d in "$STATE_ROOT"/%*; do
      [[ -d "$d" ]] || continue
      pane="$(basename "$d")"
      if ! tmux display-message -t "$pane" -p '#{pane_id}' &>/dev/null; then
        rm -rf "$d"
      fi
    done
  fi
) &>/dev/null &

TUI=false
TUI_FULL=false
while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --tui)  TUI=true; shift ;;
    --full) TUI=true; TUI_FULL=true; shift ;;
    *) break ;;
  esac
done

PANE_ID="${1:-}"
if [[ -z "$PANE_ID" ]]; then
  echo "Usage: read-tmux [--tui|--full] <pane_id>  (e.g. read-tmux %42)" >&2
  exit 1
fi

# Validate pane exists
if ! tmux display-message -t "$PANE_ID" -p '#{pane_id}' &>/dev/null; then
  echo "Error: pane '$PANE_ID' not found" >&2
  exit 1
fi

DIR="/tmp/tmux-skill/${PANE_ID}"
MARKER="$DIR/position"
HEAD=2000
TAIL=2000

# Print content; if over HEAD+TAIL bytes, show first HEAD and last TAIL with a gap message
print_capped() {
  local content="$1"
  local bytes=${#content}
  local limit=$(( HEAD + TAIL ))
  if [[ $bytes -eq 0 ]]; then
    echo "(empty)"
  elif [[ $bytes -le $limit ]]; then
    printf '%s\n' "$content"
  else
    local skipped=$(( bytes - limit ))
    local full_path="$DIR/full_output"
    printf '%s\n' "$content" > "$full_path"
    printf '%s\n' "${content:0:$HEAD}"
    echo ""
    echo "--- [... $skipped bytes omitted — full output saved to $full_path ...] ---"
    echo ""
    printf '%s\n' "${content: -$TAIL}"
  fi
}

CURRENT_HISTORY=$(tmux display-message -t "$PANE_ID" -p '#{history_size}')
CURRENT_CURSOR=$(tmux display-message -t "$PANE_ID" -p '#{cursor_y}')
CURRENT_TOTAL=$(( CURRENT_HISTORY + CURRENT_CURSOR ))

if [[ "$TUI" == true ]]; then
  mkdir -p "$DIR"
  TUI_PREV="$DIR/tui_prev"
  OUTPUT=$(tmux capture-pane -t "$PANE_ID" -p -E "$CURRENT_CURSOR")

  if [[ "$TUI_FULL" == true ]] || [[ ! -f "$TUI_PREV" ]]; then
    # First TUI read or --full: decorate, show full screen
    tmux set-option -p -t "$PANE_ID" pane-border-status top 2>/dev/null || true
    tmux set-option -p -t "$PANE_ID" pane-border-format "#[bg=yellow,fg=black,bold] ● Operated by Claude #[default]" 2>/dev/null || true
    printf '%s\n' "$OUTPUT" > "$TUI_PREV"
    print_capped "$OUTPUT"
  else
    # Diff against previous capture
    PREV=$(cat "$TUI_PREV")
    printf '%s\n' "$OUTPUT" > "$TUI_PREV"

    if [[ "$OUTPUT" == "$PREV" ]]; then
      echo "(no changes on screen)"
    else
      TOTAL_LINES=$(printf '%s\n' "$OUTPUT" | wc -l)
      CHANGED_LINES=$(diff --old-line-format='x' --new-line-format='x' --unchanged-line-format='' \
        <(printf '%s\n' "$PREV") <(printf '%s\n' "$OUTPUT") | wc -c || true)
      THRESHOLD=$(( TOTAL_LINES / 2 ))

      if [[ $CHANGED_LINES -gt $THRESHOLD ]]; then
        # Heavy redraw — show full screen
        print_capped "$OUTPUT"
      else
        # Show unified diff
        DIFF=$(diff -U1 <(printf '%s\n' "$PREV") <(printf '%s\n' "$OUTPUT") | tail -n +3 || true)
        print_capped "$DIFF"
      fi
    fi
  fi
  exit 0
fi

if [[ ! -f "$MARKER" ]]; then
  # First call — decorate pane, capture full buffer, save position
  mkdir -p "$DIR"
  tmux set-option -p -t "$PANE_ID" pane-border-status top 2>/dev/null || true
  tmux set-option -p -t "$PANE_ID" pane-border-format "#[bg=yellow,fg=black,bold] ● Operated by Claude #[default]" 2>/dev/null || true
  OUTPUT=$(tmux capture-pane -t "$PANE_ID" -p -S - -E "$CURRENT_CURSOR")
  echo "$CURRENT_TOTAL" > "$MARKER"
  print_capped "$OUTPUT"
else
  SAVED_TOTAL=$(cat "$MARKER")
  NEW_LINES=$(( CURRENT_TOTAL - SAVED_TOTAL ))
  echo "$CURRENT_TOTAL" > "$MARKER"

  if [[ $NEW_LINES -gt 0 ]]; then
    # Capture only new lines
    START=$(( CURRENT_CURSOR - NEW_LINES ))
    OUTPUT=$(tmux capture-pane -t "$PANE_ID" -p -S "$START" -E "$CURRENT_CURSOR")
    print_capped "$OUTPUT"
  elif [[ $NEW_LINES -eq 0 ]]; then
    echo "(no new output)"
  else
    # Pane was cleared/reset — show visible area up to cursor
    OUTPUT=$(tmux capture-pane -t "$PANE_ID" -p -E "$CURRENT_CURSOR")
    print_capped "$OUTPUT"
  fi
fi
